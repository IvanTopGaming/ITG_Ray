{
  "name": "itgray-electron",
  "version": "0.1.0",
  "private": true,
  "main": "dist-main/main/index.js",
  "scripts": {
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build": "npm run build:main && npm run build:preload && npm run build:bridge",
    "build:bridge": "go build -o dist-bridge/itgray-bridge ../../cmd/itgray-bridge",
    "dev": "concurrently -k -n bridge,main \"npm:dev:bridge\" \"npm:dev:main\"",
    "dev:bridge": "go build -o dist-bridge/itgray-bridge ../../cmd/itgray-bridge && cross-env ELECTRON_DEV=1 wait-on dist-bridge/itgray-bridge && cross-env ELECTRON_DEV=1 npm run start:dev",
    "dev:main": "tsc -b --watch",
    "start:dev": "cross-env ELECTRON_DEV=1 electron .",
    "start": "electron ."
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^31.0.0",
    "typescript": "^5.6.0",
    "wait-on": "^7.2.0"
  }
}
